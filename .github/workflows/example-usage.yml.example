# 이 파일은 예시입니다. 실제 사용 시 .example 확장자를 제거하고 사용하세요.
# This is an example file. Remove the .example extension for actual use.

name: AI Code Review

on:
  pull_request:
    types: [opened, synchronize, reopened]

jobs:
  review:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      pull-requests: write

    steps:
      - uses: actions/checkout@v4

      # Claude를 사용하는 경우
      - name: AI Code Review (Claude)
        uses: k1my3ch4n/ai-code-reviewer@v1
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          ai-provider: 'claude'
          claude-api-key: ${{ secrets.CLAUDE_API_KEY }}
          language: 'ko'
          exclude-patterns: '*.lock,*.md,*.json,*.yml,*.yaml,*.svg,*.png'

      # 또는 Gemini를 사용하는 경우
      # - name: AI Code Review (Gemini)
      #   uses: k1my3ch4n/ai-code-reviewer@v1
      #   with:
      #     github-token: ${{ secrets.GITHUB_TOKEN }}
      #     ai-provider: 'gemini'
      #     gemini-api-key: ${{ secrets.GEMINI_API_KEY }}
      #     language: 'ko'
